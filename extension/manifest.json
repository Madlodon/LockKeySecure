{
    "name": "LockKeySecure",
    "version": "1.0",
    "manifest_version": 3,
    "description": "Remplit automatiquement les champs de connexion avec vos identifiants LockKeySecure.",
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["dist/credentials.js"],
        "run_at": "document_idle"
    }],
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://laniproject.dev/*"
    ]
}
