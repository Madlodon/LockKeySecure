{
    "name": "Auto filling",
    "version": "1.0",
    "manifest_version": 2,
    "description": "Extension qui rempli automatiquement les champs comme 'mail' et 'password'.",
    "browser_action": {
        "default_icon": "icon.png",
        "default_popup": "dist/index.js"
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["dist/credentials.js"],
        "run_at": "document_idle"
    }]
}
